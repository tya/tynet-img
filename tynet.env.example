# tynet.env.example — reference format for build-node's node inventory.
#
# This file is for documentation only. The real `tynet.env` on the kickstart
# host is GENERATED by Ansible in ../tynet-infra from its inventory. Edit
# tynet-infra/inventory/{group_vars/all.yml,host_vars/<host>.yml} and re-run
# `make kickstart` to update the deployed file.
#
# Bash-sourceable. build-node, check-status, check-boot-config, and verify-boot
# all source `${TYNET_ENV:-${SCRIPT_DIR}/tynet.env}`.

KICKSTART_IP=10.0.60.100
KICKSTART_MAC=dca632807952  # no colons (netconsole kernel param format)
SUBNET=10.0.60.0/24
DOMAIN=tynet.us

# Short names of all nodes (used by Makefile for bulk targets)
NODES=(pi2 pi3)

# Per-node config: NODE_<SHORTNAME_UPPERCASE>_<FIELD>=value
# Required fields: SERIAL, MAC, IP, RELEASE
# Optional fields: OVERLAY_DEV (SSD partition for overlay upper layer)

NODE_PI2_SERIAL=244634d3
NODE_PI2_MAC=dc-a6-32-8d-f3-ca
NODE_PI2_IP=10.0.60.202
NODE_PI2_RELEASE=ubuntu-22.04

NODE_PI3_SERIAL=a43386be
NODE_PI3_MAC=dc-a6-32-80-2a-cc
NODE_PI3_IP=10.0.60.203
NODE_PI3_RELEASE=ubuntu-22.04
