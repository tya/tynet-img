#!/usr/bin/env bash
set -ex

################################################################################
# Prepare a netboot image for a node.
# Server-side NFS exports, overlay directories, TFTP bind-mounts, and service
# restarts are managed by Ansible (ansible/roles/kickstart).
#
# Usage: sudo ./serve-img [kickstart_ip] [serial] [hostname]
################################################################################

function main {
  local kickstart_ip=${1:?"kickstart_ip required"}
  local serial=${2:?"serial required"}
  local hostname=${3:-${serial}}

  local root_dir
  root_dir=$(./customize-img "${kickstart_ip}" "${serial}" "${hostname}")
  [ -n "${root_dir}" ] || { echo "error: customize-img produced no output" >&2; exit 1; }

  echo -n "Image ready at " 1>&2; echo "${root_dir}"
}

main "$@"
