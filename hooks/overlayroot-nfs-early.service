[Unit]
Description=Set up overlayfs on NFS root
DefaultDependencies=no
After=local-fs-pre.target
Before=local-fs.target sysinit.target
ConditionKernelCommandLine=overlay_host
# Only run if root is NFS (not already overlayfs)
ConditionPathExists=!/run/overlayroot-nfs.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/overlayroot-nfs-setup
RemainAfterExit=yes

[Install]
WantedBy=local-fs.target
