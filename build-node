#!/usr/bin/env bash
# build-node — provision a Pi node's TFTP directory and overlay dirs
# Run on kickstart (requires root for mkdir on /srv/tftpboot and /exports/overlay).
#
# Usage: build-node <hostname>
#   hostname  e.g. pi2.tynet.us or pi2
#
# Reads node config from nodes.conf in the same directory.
# Syncs boot files from /exports/netboot/<release>/boot/ to /srv/tftpboot/<mac>/,
# writes per-node cmdline.txt, and creates overlay dirs.

set -euo pipefail

SCRIPT_DIR=$(dirname "$0")

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2; }

function usage {
  echo "Usage: build-node <hostname>"
  echo "  hostname  e.g. pi2.tynet.us or pi2"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage; exit 0
fi

hostname=${1:?"hostname required — Usage: build-node <hostname>"}

# Source node inventory
env_file="${TYNET_ENV:-${SCRIPT_DIR}/tynet.env}"
[[ -f "${env_file}" ]] || { log "ERROR: env file not found at ${env_file}"; exit 1; }
# shellcheck source=/dev/null
source "${env_file}"

# Resolve short name: strip domain if given (pi2.tynet.us → pi2)
short=${hostname%%.*}
key=$(tr '[:lower:]' '[:upper:]' <<< "${short}")  # uppercase for variable lookup: pi2 → PI2

# Look up node config
serial_var="NODE_${key}_SERIAL"
mac_var="NODE_${key}_MAC"
ip_var="NODE_${key}_IP"
release_var="NODE_${key}_RELEASE"
overlay_dev_var="NODE_${key}_OVERLAY_DEV"

serial=${!serial_var:-}
mac=${!mac_var:-}
node_ip=${!ip_var:-}
nfs_release=${!release_var:-}
overlay_dev=${!overlay_dev_var:-}

[[ -n "${serial}"      ]] || { log "ERROR: ${serial_var} not set in ${env_file}"; exit 1; }
[[ -n "${mac}"         ]] || { log "ERROR: ${mac_var} not set in ${env_file}"; exit 1; }
[[ -n "${node_ip}"     ]] || { log "ERROR: ${ip_var} not set in ${env_file}"; exit 1; }
[[ -n "${nfs_release}" ]] || { log "ERROR: ${release_var} not set in ${env_file}"; exit 1; }

root_dir="/exports/netboot/${nfs_release}"
tftp_dir="/srv/tftpboot/${mac}"
overlay_dir="/exports/overlay/${hostname}"

# Detect cloud-init key: check seed dir for serial first, then MAC
cloudinit_dir="${SCRIPT_DIR}/serve-cloud-init/cloud-init"
if [[ -d "${cloudinit_dir}/${serial}" ]]; then
  cloudinit_key="${serial}"
elif [[ -d "${cloudinit_dir}/${mac}" ]]; then
  cloudinit_key="${mac}"
else
  log "ERROR: no cloud-init seed dir found for serial=${serial} or mac=${mac} in ${cloudinit_dir}"; exit 1
fi

log "========================================"
log "build-node: ${hostname}"
log "  serial:        ${serial}"
log "  mac:           ${mac}"
log "  cloudinit_key: ${cloudinit_key}"
log "  ip:            ${node_ip}"
log "  release:       ${nfs_release}"
log "  overlay_dev:   ${overlay_dev:-(none — tmpfs+NFS fallback)}"
log "  tftp_dir:      ${tftp_dir}"
log "========================================"

[[ -d "${root_dir}/usr" ]] \
  || { log "ERROR: ${root_dir} does not exist or is not a valid image — run customize-img ${nfs_release} first"; exit 1; }

# 1. Create TFTP directory
log "--- create TFTP dir"
mkdir -p "${tftp_dir}"

# 2. Sync boot files (firmware, kernel, DTBs, overlays) from shared image
log "--- sync boot files"
rsync -a --update "${root_dir}/boot/" "${tftp_dir}/"
chmod -R a+r "${tftp_dir}/"

# 3. Write per-node cmdline.txt
log "--- write cmdline.txt"
overlay_dev_param=""
[[ -n "${overlay_dev}" ]] && overlay_dev_param=" overlay_dev=${overlay_dev}"
cmdline="console=serial0,115200 console=tty1 root=/dev/nfs nfsroot=${KICKSTART_IP}:${root_dir},vers=3 ro ip=dhcp rootwait swiotlb=noforce overlay_host=${hostname}${overlay_dev_param} netconsole=6665@${node_ip}/eth0,6666@${KICKSTART_IP}/${KICKSTART_MAC} ds=nocloud;s=http://${KICKSTART_IP}:8000/${cloudinit_key}/"
echo "${cmdline}" > "${tftp_dir}/cmdline.txt"

# 4. Create overlay dirs
log "--- create overlay dirs"
mkdir -p "${overlay_dir}/upper" "${overlay_dir}/work"

# 5. Render ssh_authorized_keys in user-data from keys/*.pub
log "--- render ssh_authorized_keys from keys/*.pub"
keys_dir="${SCRIPT_DIR}/keys"
user_data="${cloudinit_dir}/${cloudinit_key}/user-data"
if [[ -f "${user_data}" ]] && compgen -G "${keys_dir}/*.pub" > /dev/null; then
  tmp=$(mktemp)
  awk -v keys_dir="${keys_dir}" '
    /^[[:space:]]+ssh_authorized_keys:[[:space:]]*$/ {
      print
      match($0, /^[[:space:]]+/)
      indent = substr($0, 1, RLENGTH) "  "
      cmd = "cat " keys_dir "/*.pub"
      while ((cmd | getline line) > 0) {
        if (line != "") print indent "- " line
      }
      close(cmd)
      in_keys = 1
      next
    }
    in_keys && /^[[:space:]]+-[[:space:]]/ { next }
    in_keys { in_keys = 0 }
    { print }
  ' "${user_data}" > "${tmp}"
  mv "${tmp}" "${user_data}"
else
  log "WARN: skipping ssh_authorized_keys render (user-data=${user_data}, keys=${keys_dir})"
fi

log "========================================"
log "build-node SUCCESS — ${hostname}"
log "  tftp:    ${tftp_dir}/cmdline.txt"
log "  overlay: ${overlay_dir}/{upper,work}"
log "========================================"
