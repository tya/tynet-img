#!/usr/bin/env bash
set -Eeuo pipefail

################################################################################
# paths
################################################################################
# Hooks ship with the deb at /usr/share/tynet-img/hooks/. When running from
# a git checkout, fall back to ./hooks/ alongside this script.
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
if [[ -d "${SCRIPT_DIR}/hooks" ]]; then
  HOOKS_DIR="${SCRIPT_DIR}/hooks"
else
  HOOKS_DIR="/usr/share/tynet-img/hooks"
fi

################################################################################
# logging
################################################################################
LOG_DIR=/var/log/tynet-img
mkdir -p "${LOG_DIR}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2; }

step() {
  _step_name=$*
  _step_start=${SECONDS}
  log "--- ${_step_name}"
}

step_done() {
  log "    done ($((SECONDS - _step_start))s)"
}

################################################################################
# functions
################################################################################
function usage {
  echo "Usage: customize-img [nfs_release]"
  echo "  nfs_release  name of the release directory under /exports/netboot/"
  echo "               (default: ubuntu-22.04)"
  echo ""
  echo "Customizes the shared base image for NFS netboot. Node-specific config"
  echo "(cmdline.txt, TFTP dirs) is handled separately by build-node."
}

##
# customize_root — modify the root filesystem for NFS netboot
function customize_root {
  local root_dir=${1}

  # fstab - no root entry: overlayfs is set up by initramfs and systemd must
  # not remount / from fstab (that would override the overlay with ro NFS).
  echo "" > "${root_dir}/etc/fstab"

  # disable resizefs
  touch "${root_dir}/etc/growroot-disabled"

  # netplan: configure eth0 with DHCP and critical: true so systemd-networkd
  # keeps the DHCP lease during startup and doesn't disrupt the NFS lower layer.
  mkdir -p "${root_dir}/etc/netplan"
  cat > "${root_dir}/etc/netplan/00-netboot.yaml" << 'NETPLAN'
network:
  version: 2
  ethernets:
    eth0:
      dhcp4: true
      critical: true
      dhcp4-overrides:
        use-dns: true
        use-routes: true
NETPLAN

  # Disable cloud-init network management: we configure networking via netplan
  # above. Without this, cloud-init may overwrite our netplan or run dhcpcd,
  # conflicting with systemd-networkd and disrupting the NFS connection.
  mkdir -p "${root_dir}/etc/cloud/cloud.cfg.d"
  cat > "${root_dir}/etc/cloud/cloud.cfg.d/99-netboot.cfg" << 'CLOUDINIT'
# Disable cloud-init network management — handled by netplan/systemd-networkd
network:
  config: disabled
CLOUDINIT
}

##
# prepare_boot — flatten os_prefix layout and download Pi 4 firmware.
# Node-specific config (cmdline.txt) is written by build-node, not here.
function prepare_boot {
  local boot_dir=${1}

  # Newer raspi images use os_prefix=current/ for A/B updates, but TFTP netboot
  # needs files at the boot partition root. Flatten current/ into root and remove
  # os_prefix so the Pi bootloader finds DTBs, overlays, and kernel without prefix.
  if [[ -d "${boot_dir}/current" ]]; then
    rsync -a "${boot_dir}/current/" "${boot_dir}/"
    sed -i '/^os_prefix=/d' "${boot_dir}/config.txt"
  fi

  # Pi 4 netboot firmware — Ubuntu images don't ship start4.elf/fixup4.dat
  # at the TFTP-accessible boot partition root (they assume EEPROM-based SD boot).
  # Download directly from the upstream rpi-firmware repo to ensure compatibility.
  wget -q https://github.com/raspberrypi/rpi-firmware/raw/master/start4.elf -O "${boot_dir}/start4.elf"
  wget -q https://github.com/raspberrypi/rpi-firmware/raw/master/fixup4.dat -O "${boot_dir}/fixup4.dat"
}

##
# install_overlay_hook - inject overlayroot-nfs into the image's initramfs
# and install the overlayroot-nfs-sync shutdown service.
# Detects whether the image uses dracut (ubuntu-26.04+raspi) or
# initramfs-tools (ubuntu-22.04+raspi) and installs accordingly.
function install_overlay_hook {
  local root_dir=${1}

  if [[ -x "${root_dir}/usr/bin/dracut" ]]; then
    # dracut-based image: install as a dracut module
    # Detect by binary, not /usr/lib/dracut directory: bcache-tools installs a
    # 90bcache module under that path even on initramfs-tools-based images.
    local module_dir="${root_dir}/usr/lib/dracut/modules.d/50overlayroot-nfs"
    mkdir -p "${module_dir}"
    cp "${HOOKS_DIR}/overlayroot-nfs-dracut-setup.sh" "${module_dir}/module-setup.sh"
    cp "${HOOKS_DIR}/overlayroot-nfs-dracut.sh"       "${module_dir}/overlayroot-nfs.sh"
    chmod +x "${module_dir}/module-setup.sh" "${module_dir}/overlayroot-nfs.sh"

    # Force dracut to include the nfs module: dracut's 74nfs check() may return 255
    # (skip) when hostonly is not set and mount_needs is empty, even though NFS root
    # is required at boot. Explicitly adding it ensures nfs.ko + mount tools are present.
    mkdir -p "${root_dir}/etc/dracut.conf.d"
    cat > "${root_dir}/etc/dracut.conf.d/netboot.conf" << 'DEOF'
# Force NFS root and overlayroot-nfs module inclusion for netboot.
add_dracutmodules+=" nfs overlayroot-nfs "
DEOF
  else
    # initramfs-tools-based image: install as init-bottom hook
    local hook_dst="${root_dir}/etc/initramfs-tools/scripts/init-bottom/overlayroot-nfs"
    mkdir -p "$(dirname "${hook_dst}")"
    cp "${HOOKS_DIR}/overlayroot-nfs" "${hook_dst}"
    chmod +x "${hook_dst}"
  fi

  # Shutdown sync service: copies tmpfs upper back to NFS state store on reboot/shutdown
  local svc_dst=${root_dir}/etc/systemd/system/overlayroot-nfs-sync.service
  cat > "${svc_dst}" << 'EOF'
[Unit]
Description=Sync overlay upper layer back to NFS state store
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target

[Service]
Type=oneshot
RemainAfterExit=no
ExecStart=/usr/local/sbin/overlayroot-nfs-sync

[Install]
WantedBy=halt.target reboot.target shutdown.target
EOF

  cp "${HOOKS_DIR}/overlayroot-nfs-sync" "${root_dir}/usr/local/sbin/overlayroot-nfs-sync"
  chmod +x "${root_dir}/usr/local/sbin/overlayroot-nfs-sync"

  # Enable the service
  mkdir -p "${root_dir}/etc/systemd/system/halt.target.wants"
  mkdir -p "${root_dir}/etc/systemd/system/reboot.target.wants"
  mkdir -p "${root_dir}/etc/systemd/system/shutdown.target.wants"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/halt.target.wants/overlayroot-nfs-sync.service"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/reboot.target.wants/overlayroot-nfs-sync.service"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/shutdown.target.wants/overlayroot-nfs-sync.service"
}

##
# validate_initramfs - verify overlayroot-nfs hook is present in the rebuilt initramfs.
# Runs lsinitramfs inside the image via nspawn — host's lsinitramfs can fail to
# decompress some images (e.g. LZ4 with newer headers). Checks both
# initramfs-tools (init-bottom) and dracut (pre-pivot/initqueue) hook paths.
function validate_initramfs {
  local root_dir=${1}
  local initramfs="${root_dir}/boot/initrd.img"

  [[ -f "${initramfs}" ]] \
    || { log "ERROR: initramfs not found at ${initramfs}"; exit 1; }

  # Capture into a variable first — pipefail + grep -q would SIGPIPE nspawn
  # mid-output and fail the pipeline even when the match is present.
  local listing
  listing=$(systemd-nspawn -q -D "${root_dir}" lsinitramfs /boot/initrd.img 2>/dev/null)
  echo "${listing}" \
    | grep -qE '(scripts/init-bottom/overlayroot-nfs|dracut/hooks/(pre-pivot|initqueue)/[0-9]+-overlayroot-nfs)' \
    || { log "ERROR: overlayroot-nfs hook not found in initramfs — rebuild may have failed silently"; exit 1; }
}

##
# rebuild_initramfs - run update-initramfs inside the extracted image.
# Uses systemd-nspawn which handles /proc /dev /sys automatically and
# works reliably for both native and cross-arch builds.
function rebuild_initramfs {
  local root_dir=${1}

  # systemd-nspawn requires /dev to be a pre-mounted filesystem, not a
  # populated directory on the same fs as root. Unmount any leftover mounts
  # from prior failed runs, then mount a fresh tmpfs for nspawn to populate.
  awk -v p="${root_dir}/dev" '$2 ~ "^"p {print $2}' /proc/mounts \
    | sort -r | xargs -r umount -lf 2>/dev/null || true
  umount -lf "${root_dir}/dev" 2>/dev/null || true
  mount -t tmpfs tmpfs "${root_dir}/dev"
  trap 'umount -lf "${root_dir}/dev" 2>/dev/null || true' RETURN

  DEBIAN_FRONTEND=noninteractive \
    systemd-nspawn --bind-ro=/etc/resolv.conf -D "${root_dir}" \
    bash -c 'apt-get install -y nfs-common && update-initramfs -c -k all && cp --remove-destination /boot/initrd.img-* /boot/initrd.img'
}

##
# main
function customize-img {
  local nfs_release=${1:-ubuntu-22.04}
  local root_dir="/exports/netboot/${nfs_release}"

  local logfile
  logfile="${LOG_DIR}/customize-img-$(date +%Y%m%d-%H%M%S)-${nfs_release}.log"
  ln -sf "${logfile}" "${LOG_DIR}/latest.log"
  exec > >(tee -a "${logfile}") 2> >(tee -a "${logfile}" >&2)

  log "========================================"
  log "customize-img start"
  log "  nfs_release: ${nfs_release}"
  log "  root_dir:    ${root_dir}"
  log "  log:         ${logfile}"
  log "========================================"

  trap 'log "FAILED (exit $?) after $((SECONDS))s — see ${logfile}"' ERR

  step "extract-img"
  # When running from a git checkout, prefer the sibling script over PATH.
  if [[ -x "${SCRIPT_DIR}/extract-img" ]]; then
    "${SCRIPT_DIR}/extract-img" "${nfs_release}"
  else
    extract-img "${nfs_release}"
  fi
  [[ -d "${root_dir}/usr" ]] \
    || { log "extract-img produced invalid root at ${root_dir}"; exit 1; }
  log "    root: ${root_dir} (${SECONDS}s elapsed)"

  local boot_dir="${root_dir}/boot"

  step "customize_root"
  customize_root "${root_dir}"
  log "    done (${SECONDS}s elapsed)"

  step "prepare_boot"
  prepare_boot "${boot_dir}"
  log "    done (${SECONDS}s elapsed)"

  step "install_overlay_hook"
  install_overlay_hook "${root_dir}"
  log "    done (${SECONDS}s elapsed)"

  step "rebuild_initramfs"
  rebuild_initramfs "${root_dir}"
  log "    done (${SECONDS}s elapsed)"

  step "validate_initramfs"
  validate_initramfs "${root_dir}"
  log "    done (${SECONDS}s elapsed)"

  log "========================================"
  log "customize-img SUCCESS — ${nfs_release} (${SECONDS}s total)"
  log "========================================"
}

################################################################################
# entrypoint
################################################################################
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage; exit 0
fi

customize-img "$@"
