#!/usr/bin/env bash
set -ex

################################################################################
# functions
################################################################################
##
# usage
function usage {
  echo Usage: customize-img-[10.0.10.13] 
}

##
# customize_root
function customize_root {
  local root_dir=${1}
  local ip=${2}

  # fstab
  local fsline="${ip}:${root_dir}/ / nfs defaults,rw,nolock,errors=remount-ro 0 0"
  echo "${fsline}" > ${root_dir}/etc/fstab

  # disable resizefs
  touch ${root_dir}/etc/growroot-disabled
}

##
# customize_boot
function customize_boot {
  local boot_dir=${1}
  local ip=${2}

  # cmdline.txt
  local cmdline="console=tty1 root=/dev/nfs nfsroot=${ip}:${root_dir},vers=3 rw ip=dhcp rootwait"
  echo "${cmdline}" > ${boot_dir}/cmdline.txt

  # customize firmeware (why? tbd)
  rm ${boot_dir}/start4.elf
  rm ${boot_dir}/fixup4.dat
  wget https://github.com/raspberrypi/rpi-firmware/raw/master/start4.elf -P ${boot_dir}/
  wget https://github.com/raspberrypi/rpi-firmware/raw/master/fixup4.dat -P ${boot_dir}/
}

##
# customize image for netboot
function customize-img {
  local kickstart_ip=${1:-"10.0.10.13"}
  local root_dir
  read root_dir <<< $(./extract-img)
  local boot_dir=${root_dir}/boot
  
  customize_root ${root_dir} ${kickstart_ip}
  customize_boot ${boot_dir} ${kickstart_ip}

  echo ${root_dir}
}

################################################################################
# entrypoint
################################################################################
customize-img "$@"
