#!/usr/bin/env bash
set -Eeuo pipefail

################################################################################
# functions
################################################################################
##
# usage
function usage {
  echo "Usage: customize-img [kickstart_ip] [serial] [hostname]"
}

##
# customize_root
function customize_root {
  local root_dir=${1}
  local ip=${2}

  # fstab - ro since overlayfs handles writes
  local fsline="${ip}:${root_dir}/ / nfs defaults,ro,nolock,errors=remount-ro 0 0"
  echo "${fsline}" > "${root_dir}/etc/fstab"

  # disable resizefs
  touch "${root_dir}/etc/growroot-disabled"
}

##
# customize_boot
function customize_boot {
  local boot_dir=${1}
  local ip=${2}
  local serial=${3}
  local hostname=${4}
  local root_dir=${5}

  # cmdline.txt - ro NFS root + overlay_host for per-node overlayfs
  local cmdline="console=serial0,115200 console=tty1 root=/dev/nfs nfsroot=${ip}:${root_dir},vers=3 ro ip=dhcp rootwait overlay_host=${hostname} ds=nocloud;s=http://${ip}:8000/${serial}/"
  echo "${cmdline}" > "${boot_dir}/cmdline.txt"
}

##
# install_overlay_hook - inject overlayroot-nfs into the image's initramfs
# and install the overlayroot-nfs-sync shutdown service
function install_overlay_hook {
  local root_dir=${1}
  local script_dir
  script_dir=$(dirname "$0")
  local hook_dst=${root_dir}/etc/initramfs-tools/scripts/init-bottom/overlayroot-nfs

  mkdir -p "$(dirname "${hook_dst}")"
  cp "${script_dir}/hooks/overlayroot-nfs" "${hook_dst}"
  chmod +x "${hook_dst}"

  # Shutdown sync service: copies tmpfs upper back to NFS state store on reboot/shutdown
  local svc_dst=${root_dir}/etc/systemd/system/overlayroot-nfs-sync.service
  cat > "${svc_dst}" << 'EOF'
[Unit]
Description=Sync overlay upper layer back to NFS state store
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target
Requires=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=no
ExecStart=/usr/local/sbin/overlayroot-nfs-sync

[Install]
WantedBy=halt.target reboot.target shutdown.target
EOF

  cp "${script_dir}/hooks/overlayroot-nfs-sync" "${root_dir}/usr/local/sbin/overlayroot-nfs-sync"
  chmod +x "${root_dir}/usr/local/sbin/overlayroot-nfs-sync"

  # Enable the service
  mkdir -p "${root_dir}/etc/systemd/system/halt.target.wants"
  mkdir -p "${root_dir}/etc/systemd/system/reboot.target.wants"
  mkdir -p "${root_dir}/etc/systemd/system/shutdown.target.wants"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/halt.target.wants/overlayroot-nfs-sync.service"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/reboot.target.wants/overlayroot-nfs-sync.service"
  ln -sf /etc/systemd/system/overlayroot-nfs-sync.service \
    "${root_dir}/etc/systemd/system/shutdown.target.wants/overlayroot-nfs-sync.service"
}

##
# rebuild_initramfs - run update-initramfs inside the extracted image.
# Uses systemd-nspawn which handles /proc /dev /sys automatically and
# works reliably for both native and cross-arch builds.
function rebuild_initramfs {
  local root_dir=${1}
  local host_arch
  host_arch=$(uname -m)
  local qemu_bin=/usr/bin/qemu-aarch64-static

  # systemd-nspawn requires /dev to be a pre-mounted filesystem, not a
  # populated directory on the same fs as root. Unmount any leftover mounts
  # from prior failed runs, then mount a fresh tmpfs for nspawn to populate.
  awk -v p="${root_dir}/dev" '$2 ~ "^"p {print $2}' /proc/mounts \
    | sort -r | xargs -r umount -lf 2>/dev/null || true
  umount -lf "${root_dir}/dev" 2>/dev/null || true
  mount -t tmpfs tmpfs "${root_dir}/dev"
  trap 'umount -lf "${root_dir}/dev"' RETURN

  # Cross-arch: install qemu static binary so aarch64 binaries run on x86_64
  if [ "${host_arch}" != "aarch64" ]; then
    if [ ! -f "${qemu_bin}" ]; then
      apt-get install -y qemu-user-static > /dev/null
    fi
    cp "${qemu_bin}" "${root_dir}/usr/bin/"
    trap 'rm -f "${root_dir}/usr/bin/qemu-aarch64-static"' RETURN
  fi

  DEBIAN_FRONTEND=noninteractive \
    systemd-nspawn -D "${root_dir}" update-initramfs -u -k all
}

##
# customize image for netboot
function customize-img {
  local kickstart_ip=${1:?"kickstart_ip required"}
  local serial=${2:?"serial required"}
  local hostname=${3:-${serial}}
  local root_dir
  read -r root_dir <<< "$(./extract-img)"
  local boot_dir=${root_dir}/boot

  customize_root "${root_dir}" "${kickstart_ip}"
  customize_boot "${boot_dir}" "${kickstart_ip}" "${serial}" "${hostname}" "${root_dir}"
  install_overlay_hook "${root_dir}"
  rebuild_initramfs "${root_dir}"

  echo "${root_dir}"
}

################################################################################
# entrypoint
################################################################################
customize-img "$@"
