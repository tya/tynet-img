#!/usr/bin/env bash
# check-status — show per-node netboot status
# Run on kickstart.

set -euo pipefail

SCRIPT_DIR=$(dirname "$0")
OVERLAY_DIR=/exports/overlay

# Load node inventory
env_file="${TYNET_ENV:-${SCRIPT_DIR}/tynet.env}"
# shellcheck source=/dev/null
source "${env_file}"

# Build fully-qualified hostname list from NODES short names
HOSTNAMES=()
for short in "${NODES[@]}"; do
  key=${short^^}
  ip_var="NODE_${key}_IP"
  # Use hostname if resolvable, fall back to short name with domain
  HOSTNAMES+=("${short}.${DOMAIN:-tynet.us}")
done

# 1Password public key fingerprint — expected SSH host key for all nodes
EXPECTED_FP="SHA256:n6ooJKYiOdTmhUyOPG9OFj2BZjAvRcfvNzKnJBNkcQg"

printf "%-20s  %-6s  %-18s  %-10s  %-10s  %-12s  %s\n" \
  "NODE" "STATUS" "RELEASE" "OVERLAY" "UPPER" "SSH KEY" "LAST SYNC"
printf "%-20s  %-6s  %-18s  %-10s  %-10s  %-12s  %s\n" \
  "----" "------" "-------" "-------" "-----" "-------" "---------"

for node in "${HOSTNAMES[@]}"; do
  # Determine UP/DOWN by ping — showmount data can be stale
  if ping -c1 -W1 "${node}" &>/dev/null; then
    status="UP"
  else
    status="DOWN"
  fi

  # Get configured release and overlay_dev from cmdline.txt
  cmdline=$(grep -rl "overlay_host=${node}" /srv/tftpboot/ 2>/dev/null | head -1 || true)
  if [[ -n "${cmdline}" ]]; then
    release=$(grep -o 'nfsroot=[^ ]*' "${cmdline}" | sed 's|.*netboot/||;s|,.*||')
    if grep -q 'overlay_dev=' "${cmdline}" 2>/dev/null; then
      configured_upper="ssd"
    else
      configured_upper="tmpfs"
    fi
  else
    release="—"
    configured_upper="—"
  fi

  # Overlay mode and SSH key fingerprint — check on the node if it's up
  if [[ "${status}" == "UP" ]]; then
    node_info=$(ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new "${node}" \
      "df --output=size / 2>/dev/null | tail -1; ssh-keygen -l -f /etc/ssh/ssh_host_ed25519_key.pub 2>/dev/null || echo 'no-key'" \
      2>/dev/null || echo "")

    if [[ -n "${node_info}" ]]; then
      overlay_size=$(echo "${node_info}" | head -1 | tr -d ' ')
      # df size is in 1K blocks; SSD is > 100GB = 100M blocks
      if [[ "${overlay_size}" -gt 100000000 ]] 2>/dev/null; then
        upper="ssd"
      else
        upper="tmpfs"
      fi

      key_line=$(echo "${node_info}" | tail -1)
      if [[ "${key_line}" == "no-key" ]]; then
        ssh_key="missing"
      else
        actual_fp=$(echo "${key_line}" | awk '{print $2}')
        if [[ "${actual_fp}" == "${EXPECTED_FP}" ]]; then
          ssh_key="ok (1pw)"
        else
          ssh_key="WRONG KEY"
        fi
      fi
    else
      upper="?"
      ssh_key="no-ssh"
    fi
  else
    upper="—"
    ssh_key="—"
  fi

  # Last sync: mtime of the overlay upper dir on kickstart
  upper_dir="${OVERLAY_DIR}/${node}/upper"
  if [[ -d "${upper_dir}" ]]; then
    last_sync=$(stat -c '%y' "${upper_dir}" | cut -c1-16)
  else
    last_sync="never"
  fi

  printf "%-20s  %-6s  %-18s  %-10s  %-10s  %-12s  %s\n" \
    "${node}" "${status}" "${release}" "${configured_upper}" "${upper}" "${ssh_key}" "${last_sync}"
done
