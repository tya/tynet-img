#!/usr/bin/env bash
# check-status — show per-node netboot status
# Run on kickstart.

set -euo pipefail

OVERLAY_DIR=/exports/overlay
NODES=(pi1.tynet.us pi2.tynet.us pi3.tynet.us)

printf "%-20s  %-8s  %-20s  %-8s  %s\n" "NODE" "STATUS" "RELEASE" "OVERLAY" "LAST SYNC"
printf "%-20s  %-8s  %-20s  %-8s  %s\n" "----" "------" "-------" "-------" "---------"

for node in "${NODES[@]}"; do
  # Determine UP/DOWN by ping — showmount data can be stale
  if ping -c1 -W1 "${node}" &>/dev/null; then
    status="UP"
  else
    status="DOWN"
  fi

  # Get configured release from cmdline.txt — more reliable than showmount which can be stale.
  # Works with both serial-keyed and MAC-keyed TFTP dirs.
  cmdline=$(grep -rl "overlay_host=${node}" /srv/tftpboot/ 2>/dev/null | head -1 || true)
  if [[ -n "${cmdline}" ]]; then
    release=$(grep -o 'nfsroot=[^ ]*' "${cmdline}" | sed 's|.*netboot/||;s|,.*||')
  else
    release="—"
  fi

  # Overlay: check /proc/mounts on the node if it's up
  if [[ "${status}" == "UP" ]]; then
    if ssh -o ConnectTimeout=3 -o BatchMode=yes -o StrictHostKeyChecking=accept-new "${node}" \
        "grep -q 'exports/overlay' /proc/mounts" 2>/dev/null; then
      overlay="active"
    else
      overlay="none"
    fi
  else
    overlay="inactive"
  fi

  # Last sync: mtime of the overlay upper dir on kickstart
  upper="${OVERLAY_DIR}/${node}/upper"
  if [[ -d "${upper}" ]]; then
    last_sync=$(stat -c '%y' "${upper}" | cut -c1-16)
  else
    last_sync="never"
  fi

  printf "%-20s  %-8s  %-20s  %-8s  %s\n" "${node}" "${status}" "${release}" "${overlay}" "${last_sync}"
done
