# vm.env — Lima VM test environment
# Usage: TYNET_ENV=vm.env ./build-node testnode.vm
#        ENV_FILE=vm.env make status

KICKSTART_IP=192.168.105.10
KICKSTART_MAC=000000000000   # placeholder — netconsole not used in VMs
SUBNET=192.168.105.0/24
DOMAIN=vm

# Short names of all nodes (used by check-status and bulk Makefile targets)
NODES=(testnode)

# Per-node config: NODE_<SHORTNAME_UPPERCASE>_<FIELD>=value
# Required fields: SERIAL, MAC, IP, RELEASE
# Fill in MAC and IP from the Lima node VM after first boot.

NODE_TESTNODE_SERIAL=00000000
NODE_TESTNODE_MAC=00-00-00-00-00-00   # fill in from Lima node VM
NODE_TESTNODE_IP=192.168.105.11       # fill in from Lima node VM
NODE_TESTNODE_RELEASE=ubuntu-26.04
