#cloud-config
# pi3.tynet.us — HA control plane node
# After this node boots, run 'microk8s add-node' on pi2 and execute the
# resulting join command on this node:
#   microk8s join <pi2-ip>:25000/<token>

users:
  - name: ty
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: adm, sudo
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAw3CX41Cr43qst3bCnB3FNM9DdfvnvCw+9b1dI042GG

runcmd:
  - snap install microk8s --classic --channel=1.32/stable
  - usermod -aG microk8s ty
  - microk8s status --wait-ready --timeout 300
