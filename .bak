#!/usr/bin/env bash
set -ex

# # config vars
# export PI_SERIAL=244634d3
# export PI_MAC='dc:a6:32:8d:f3:ca'
# export PI_IP='10.0.10.12'
# export PI_NAME=pi2
# export KICKSTART_IP='10.0.10.13'
# export USERNAME=ty
# export PASSWORD=asdf1234
# 
# # data sources
# export OS_NAME=ubuntu_22-04-3_server_amd64
# export OS_IMG=${OS_NAME}.img
# export OS_IMG_XZ=${OS_IMG}.xz
# export BOOTMNT=/tmp/pxe/bootmnt
# export ROOTMNT=/tmp/pxe/rootmnt
# 
# # data destinations
# export NFS_DIR=/srv/nfs/${PI_NAME}
# export TFTP_DIR=/srv/tftp/${PI_SERIAL}

################################################################################
# helper functions
################################################################################
##
# ensure fstab_line
function fstab_line {
  local line=$1
  if ! grep -q "${line}" /etc/fstab
  then
    echo "${line}" >> /etc/fstab
  fi
}

##
# ensure exports line
function exports_line {
  local line=$1
  if ! grep -q "${line}" /etc/exports
  then
    echo "${line}" >> /etc/exports
  fi
}


################################################################################
# execution steps
################################################################################
##
# setup directories for netboot
function setup {
  #[ -d ${NFS_DIR} ] && echo "Error: ${NFS_DIR} already exists" && exit 1
  mkdir -p ${NFS_DIR}
  
  #[ -d ${TFTP_DIR} ] && echo "Error: ${TFTP_DIR} already exists" && exit 1
  mkdir -p ${TFTP_DIR}
  
  mkdir -p ${PXE_DIR}
  mkdir -p ${BOOTMNT}
  mkdir -p ${ROOTMNT}
}

# download img
function download {
  set +x
  [ ! -f ${PXE_DIR}/${OS_IMG} ] && wget -O ${PXE_DIR}/${OS_IMG_XZ} ${OS_URL}
  [ ! -f ${PXE_DIR}/${OS_IMG} ] && unxz ${PXE_DIR}/${OS_IMG_XZ}
  set -x
}

##
# mount-img
function mount-img {
  kpartx -a -v ${PXE_DIR}/${OS_IMG}
  mount /dev/mapper/$(kpartx -l -v ${PXE_DIR}/${OS_IMG} | cut -f1 -d' ' | head -n 1) ${BOOTMNT}
  mount /dev/mapper/$(kpartx -l -v ${PXE_DIR}/${OS_IMG} | cut -f1 -d' ' | tail -n 1) ${ROOTMNT}
}

##
# install netboot filesystems (/ and /boot) from img
function install {
  cp -a ${ROOTMNT}/* ${NFS_DIR}
  cp -a ${BOOTMNT}/* ${NFS_DIR}/boot
}

# unmount-img
function unmount-img {
  umount ${BOOTMNT}
  umount ${ROOTMNT}
  kpartx -d -v ${PXE_DIR}/${OS_IMG}
}

##
# customize filesystem
function customize {
  echo "console=serial0,115200 console=tty1 root=/dev/nfs nfsroot=${KICKSTART_IP}:${NFS_DIR},vers=3 rw ip=dhcp rootwait ds=nocloud;s=http://10.0.10.13:8000/" > ${NFS_DIR}/boot/cmdline.txt
  echo "${KICKSTART_IP}:${NFS_DIR}/ / nfs defaults,rw,nolock,errors=remount-ro 0 0" > ${NFS_DIR}/etc/fstab
  touch ${NFS_DIR}/etc/growroot-disabled
  rm ${NFS_DIR}/boot/start4.elf
  rm ${NFS_DIR}/boot/fixup4.dat
  wget https://github.com/raspberrypi/rpi-firmware/raw/master/start4.elf -P ${NFS_DIR}/boot/
  wget https://github.com/raspberrypi/rpi-firmware/raw/master/fixup4.dat -P ${NFS_DIR}/boot/
}

##
# serve /boot via tftpd-hpa
function serve {
  fstab_line "${NFS_DIR}/boot ${TFTP_DIR} none defaults,bind 0 0"
  mount ${TFTP_DIR}/
  sed -i  /UUID/d ${NFS_DIR}/etc/fstab
  exports_line "${NFS_DIR} ${PI_IP}(rw,sync,no_subtree_check,no_root_squash)"
}

##
# load servers with new config
function load {
  systemctl restart rpcbind
  systemctl restart nfs-server
  systemctl restart tftpd-hpa
}

##
# run steps
function main {
  setup
  download
  mount-img
  trap unmount-img EXIT 1 2 3 6
  install
  customize
  serve
  load
}

################################################################################
# entrypoint
################################################################################
main
