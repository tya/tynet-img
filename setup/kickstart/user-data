#cloud-config
# kickstart.tynet.us — netboot kickstart server
# Flash to SD card via Raspberry Pi Imager, then run Ansible to provision services.

hostname: kickstart
fqdn: kickstart.tynet.us
manage_etc_hosts: true
manage_resolv_conf: false

timezone: America/Denver
keyboard:
  model: pc105
  layout: "us"

apt:
  preserve_sources_list: true
  conf: |
    Acquire {
      Check-Date "false";
    };

packages:
  - avahi-daemon

ssh_pwauth: false

users:
  - name: ty
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
