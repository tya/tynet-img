#cloud-config
# kickstart.tynet.us — netboot kickstart server
# Flash to SD card via Raspberry Pi Imager, then run Ansible to provision services.

hostname: kickstart
fqdn: kickstart.tynet.us

users:
  - name: ty
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: adm, sudo
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAw3CX41Cr43qst3bCnB3FNM9DdfvnvCw+9b1dI042GG

network:
  version: 2
  ethernets:
    eth0:
      dhcp4: false
      addresses:
        - 10.0.60.100/24
      routes:
        - to: default
          via: 10.0.60.1
      nameservers:
        addresses:
          - 10.0.60.1
          - 1.1.1.1
          - 1.0.0.1
