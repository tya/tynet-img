# Rotate customize-img run logs in /var/log/tynet-img/
# Each run creates a new timestamped file; rotate keeps old ones compressed
# and purges after 30 days.
/var/log/tynet-img/*.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    # latest.log is a symlink — skip it
    exclude latest.log
}
