# /etc/exports — managed by Ansible (roles/kickstart)
# Do not edit manually; changes will be overwritten on next provision.

# Netboot release images (auto-discovered from /exports/netboot/)
{% for release in netboot_releases.files | sort(attribute='path') %}
{{ release.path }} {{ subnet }}(ro,sync,no_subtree_check,no_root_squash,fsid={{ loop.index0 }})
{% endfor %}

# Per-node writable overlay state store
{% for node in groups['nodes'] %}
/exports/overlay/{{ node }} {{ subnet }}(rw,sync,no_subtree_check,no_root_squash,fsid={{ hostvars[node].nfs_fsid }})
{% endfor %}
