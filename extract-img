#!/usr/bin/env bash
set -Eeuo pipefail

################################################################################
# functions
################################################################################
##
# usage
function usage {
  echo "Usage: extract-img [URL] [DOWNLOAD_DIR]"
}

# download-img
function download-img {
  local url=${1}
  local img
  img=/var/cache/img/$(basename "${url}" .xz)
  mkdir -p "$(dirname "${img}")"
  [ ! -f "${img}" ] && wget -O "${img}.xz" "${url}" && unxz "${img}.xz"
  echo "${img}"
}

##
# mount-img $path $image_dir
function mount-img {
  local img=${1}
  local img_dir
  img_dir=$(dirname "${img}")
  local root_mnt=${img_dir}/root
  local boot_mnt=${img_dir}/boot

  mkdir -p "${root_mnt}"
  mkdir -p "${boot_mnt}"

  # Raspberry Pi preinstalled images: p1=FAT boot (firmware/kernel), p2=ext4 root.
  sudo kpartx -a -s "${img}"
  sudo mount "/dev/mapper/$(kpartx -l -v "${img}" | cut -f1 -d' ' | tail -n 1)" "${root_mnt}" > /dev/null 2>&1
  sudo mount "/dev/mapper/$(kpartx -l -v "${img}" | cut -f1 -d' ' | head -n 1)" "${boot_mnt}" > /dev/null 2>&1

  echo "${root_mnt} ${boot_mnt}"
}

##
# unmount-img
function umount-img {
  local img=${1}
  local img_dir
  img_dir=$(dirname "${img}")
  local root_mnt=${img_dir}/root
  local boot_mnt=${img_dir}/boot

  sudo umount "${root_mnt}"
  sudo umount "${boot_mnt}"
  sudo kpartx -d "${img}"
}

##
# install-img
function install {
  local src=${1}
  local dst=${2}

  mkdir -p "${dst}"
  # exit 23 = partial transfer (expected for special files in OS images) — treat as success
  rsync -a --checksum --no-devices --no-specials "${src}/" "${dst}/" >&2 || { rc=$?; [ "${rc}" -eq 23 ] || exit "${rc}"; }
}

##
# extract-img
function extract-img {
  url=${1:-"https://cdimage.ubuntu.com/releases/22.04/release/ubuntu-22.04.5-preinstalled-server-arm64+raspi.img.xz"}
  dst=${2:-"/exports/netboot/$(basename "${url%.img.xz}" | sed 's/\(ubuntu-[0-9]*\.[0-9]*\).*/\1/')"}

  read -r img <<< "$(download-img "${url}")"
  read -r root_mnt boot_mnt <<< "$(mount-img "${img}")"
  trap 'umount-img ${img}' EXIT 1 2 3 6

  install "${root_mnt}" "${dst}"
  install "${boot_mnt}" "${dst}/boot"
  echo "${dst}"
}

################################################################################
# entrypoint
################################################################################
extract-img "$@"
