#!/usr/bin/env bash
set -Eeuo pipefail

################################################################################
# logging
################################################################################
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2; }

################################################################################
# functions
################################################################################
##
# usage
function usage {
  echo "Usage: extract-img [URL] [DOWNLOAD_DIR]"
}

# download-img
function download-img {
  local url=${1}
  local img
  img=/var/cache/img/$(basename "${url}" .xz)
  mkdir -p "$(dirname "${img}")"
  if [ ! -f "${img}" ]; then
    log "download-img: downloading ${url}"
    wget -O "${img}.xz" "${url}"
    log "download-img: decompressing"
    unxz "${img}.xz"
    log "download-img: done → ${img}"
  else
    log "download-img: cache hit → ${img}"
  fi
  echo "${img}"
}

##
# mount-img $path $image_dir
function mount-img {
  local img=${1}
  local img_dir
  img_dir=$(dirname "${img}")
  local root_mnt=${img_dir}/root
  local boot_mnt=${img_dir}/boot

  mkdir -p "${root_mnt}"
  mkdir -p "${boot_mnt}"

  sudo kpartx -a -s "${img}"
  local parts
  parts=$(kpartx -l -v "${img}" | cut -f1 -d' ')

  # Raspberry Pi preinstalled images (filename contains "raspi"):
  #   p1 = FAT boot (firmware/kernel), p2 = ext4 root — opposite to generic arm64.
  # Generic arm64 images: p1 = ext4 root, p2 = EFI boot.
  if [[ "${img}" == *raspi* ]]; then
    sudo mount "/dev/mapper/$(echo "${parts}" | tail -n 1)" "${root_mnt}" > /dev/null 2>&1
    sudo mount "/dev/mapper/$(echo "${parts}" | head -n 1)" "${boot_mnt}" > /dev/null 2>&1
  else
    sudo mount "/dev/mapper/$(echo "${parts}" | head -n 1)" "${root_mnt}" > /dev/null 2>&1
    sudo mount "/dev/mapper/$(echo "${parts}" | tail -n 1)" "${boot_mnt}" > /dev/null 2>&1
  fi

  echo "${root_mnt} ${boot_mnt}"
}

##
# unmount-img
function umount-img {
  local img=${1}
  local img_dir
  img_dir=$(dirname "${img}")
  local root_mnt=${img_dir}/root
  local boot_mnt=${img_dir}/boot

  sudo umount "${root_mnt}"
  sudo umount "${boot_mnt}"
  sudo kpartx -d "${img}"
}

##
# install-img
function install {
  local src=${1}
  local dst=${2}

  mkdir -p "${dst}"
  # exit 23 = partial transfer (expected for special files in OS images) — treat as success
  rsync -a --checksum --no-devices --no-specials "${src}/" "${dst}/" >&2 || { rc=$?; [ "${rc}" -eq 23 ] || exit "${rc}"; }
}

##
# extract-img
function extract-img {
  url=${1:-"https://cdimage.ubuntu.com/releases/26.04/snapshot-4/ubuntu-26.04-snapshot4-preinstalled-server-arm64+raspi.img.xz"}
  dst=${2:-"/exports/netboot/$(basename "${url}" .img.xz | cut -f1,2 -d '-')"}

  if [[ -d "${dst}/usr" ]]; then
    log "extract-img: ${dst} already populated, skipping extract"
    echo "${dst}"
    return
  fi

  log "extract-img: destination → ${dst}"

  read -r img <<< "$(download-img "${url}")"
  read -r root_mnt boot_mnt <<< "$(mount-img "${img}")"
  trap 'umount-img ${img}' EXIT 1 2 3 6

  log "extract-img: rsyncing root partition"
  install "${root_mnt}" "${dst}"
  log "extract-img: rsyncing boot partition"
  install "${boot_mnt}" "${dst}/boot"
  log "extract-img: done"
  echo "${dst}"
}

################################################################################
# entrypoint
################################################################################
extract-img "$@"
