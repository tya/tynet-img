#!/usr/bin/env bash
# check-netboot — show recent TFTP and NFS activity
# Run on kickstart. Usage: ./check-netboot [--since "N minutes ago"] [--follow]

set -euo pipefail

SINCE="5 minutes ago"
FOLLOW=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --since|-s) SINCE=$2; shift 2 ;;
    --follow|-f) FOLLOW=true; shift ;;
    *) echo "Usage: $0 [--since 'N minutes ago'] [--follow]" >&2; exit 1 ;;
  esac
done

if $FOLLOW; then
  echo "Following TFTP and NFS logs (Ctrl-C to stop)..."
  echo ""
  journalctl -f -u tftpd-hpa -u nfs-server -k 2>/dev/null \
    | grep --line-buffered -E 'tftpd|nfs|NFS|mount'
  exit 0
fi

echo "=== TFTP downloads (since: $SINCE) ==="
TFTP=$(journalctl -u tftpd-hpa --since "$SINCE" --no-pager 2>/dev/null \
  | grep RRQ \
  | awk '{print $1, $2, $3, $8, $10}')
if [[ -z "$TFTP" ]]; then
  echo "  (none)"
else
  # Group by boot attempt: a new attempt starts when we see config.txt or start4.elf
  echo "$TFTP" | awk '
    /config\.txt|start4\.elf/ { attempt++ }
    { printf "  [boot %d] %s %s %s  %-15s %s\n", attempt, $1, $2, $3, $4, $5 }
  '
fi

echo ""
echo "=== NFS mounts (since: $SINCE) ==="
NFS_LOG=$(journalctl -k --since "$SINCE" --no-pager 2>/dev/null \
  | grep -i 'nfs\|mount' || true)
if [[ -z "$NFS_LOG" ]]; then
  echo "  (none in kernel log)"
else
  echo "$NFS_LOG"
fi

echo ""
echo "=== Current NFS clients ==="
MOUNTS=$(showmount -a 2>/dev/null | grep -v "^All" || true)
if [[ -z "$MOUNTS" ]]; then
  echo "  (none)"
else
  printf "  %-16s  %-30s  %s\n" "CLIENT" "PATH" "TYPE"
  printf "  %-16s  %-30s  %s\n" "------" "----" "----"
  while IFS= read -r line; do
    ip=$(echo "${line}" | cut -d: -f1)
    path=$(echo "${line}" | cut -d: -f2-)
    hostname=$(getent hosts "${ip}" 2>/dev/null | awk '{print $2}' | cut -d. -f1)
    client="${ip}${hostname:+ (${hostname})}"
    if [[ "${path}" == */exports/netboot/* ]]; then
      release=$(basename "${path}")
      type="root (${release})"
    elif [[ "${path}" == */exports/overlay/* ]]; then
      type="overlay"
    else
      type="—"
    fi
    printf "  %-16s  %-30s  %s\n" "${client}" "${path}" "${type}"
  done <<< "${MOUNTS}"
fi
